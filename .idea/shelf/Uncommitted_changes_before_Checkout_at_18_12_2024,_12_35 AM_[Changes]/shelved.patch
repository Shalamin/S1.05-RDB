(2), section:nth-of-type(2) article:nth-of-type(1) {\n  width: 30%;\n}\n\n/*\n#####################################################\n#                                                   #\n#                       Footer                      #\n#                                                   #\n#####################################################\n*/\nfooter {\n  background-color: #304AAB;\n  padding: 20px;\n  display: flex;\n\n}\nfooter img{\n  display: inline-block;\n\n}\nfooter article {\n  background-color: #e6e1d3;\n  margin: 0 20px;\n  width: 50%;\n  height: auto;\n  padding: 20px;\n  border-radius: 20px;\n  \n\n}\nfooter article h1{\n  color: #03196c;\n  align-items: left;\n\n}\nfooter article p:nth-last-child(1) em{\n  color: #304AAB;\n  text-align: right;\n} \nfooter article p:nth-last-child(1) em:nth-last-child(1) {\n  text-align: right;\n  color: #304AAB;\n  font-size: 10px;\n  \n}\n\nfooter li a {\n  color: #03196c;\n  text-decoration: none;\n}\nfooter li a:hover {\n  color: #304AAB;\n}\nfooter li{\n  list-style-type: none;\n}\nfooter li:before{\n  content:\"• \";\n}\nfooter img{\n  margin : 0 5px;\n}\nfooter section {\n  display: flex;\n  margin-left :100px;\n \n}\nfooter section article:nth-child(1){\n  background-color: #d5c46c;\n  color :#d5c46c;\n  width: 10px;\n  height: 20px;\n  margin : 0 20px;\n}\nfooter section article:nth-of-type(2), footer section article:nth-of-type(3){\n  background-color: #d5c46c;\n  color :#03196c;\n  width: 10em;\n  height: 20px;\n  margin : 0 20px;\n}
